# Geotab (for backend session verification + local dev)
# Create a demo database at https://my.geotab.com/registration.html
GEOTAB_DATABASE=
GEOTAB_USERNAME=
GEOTAB_PASSWORD=
GEOTAB_SERVER=my.geotab.com

# Mapbox (for route optimization - backend only)
# Get at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=

# Google Maps (optional - for road distance matrix in algorithm)
# Without this, the algorithm uses Haversine (straight-line) distances
VITE_GOOGLE_MAPS_KEY=

# Bin sensor APIs (optional - for production)
# Sensoneo: https://sensoneo.com/api/
SENSONEO_API_KEY=
# Bigbelly: contact for API access
BIGBELLY_API_KEY=
